{
  "default": {
    "identifier": "default",
    "description": "Default permissions for IYERIS file explorer",
    "local": true,
    "windows": ["main", "window-*"],
    "permissions": [
      "core:app:default",
      "core:event:default",
      "core:window:default",
      "core:webview:default",
      "dialog:default",
      "updater:default",
      "process:default",
      "notification:default",
      "shell:default",
      "autostart:default",
      { "identifier": "core:window:allow-set-decorations", "allow": [{ "label": "main" }] }
    ]
  }
}
