{
  "default": {
    "identifier": "default",
    "description": "Default permissions for IYERIS file explorer",
    "local": true,
    "windows": ["main", "window-*"],
    "permissions": [
      "core:app:default",
      "core:event:default",
      "core:window:default",
      "core:window:allow-start-dragging",
      "core:webview:default",
      "dialog:default",
      "updater:default",
      "notification:default",
      "autostart:default",
      {
        "identifier": "core:window:allow-set-decorations",
        "allow": [{ "label": "main" }, { "label": "window-*" }]
      }
    ]
  },
  "main-window": {
    "identifier": "main-window",
    "description": "Permissions restricted to the main window (M8: prevent spawned webview windows from inheriting process:default).",
    "local": true,
    "windows": ["main"],
    "permissions": ["process:default"]
  }
}
