{
  "$schema": "https://schema.tauri.app/capabilities/2",
  "identifier": "default",
  "description": "Default permissions for IYERIS file explorer",
  "windows": ["main", "window-*"],
  "permissions": [
    "core:app:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:webview:default",
    "dialog:default",
    "updater:default",
    "process:default",
    "notification:default",
    "autostart:default",
    {
      "identifier": "core:window:allow-set-decorations",
      "allow": [{ "label": "main" }, { "label": "window-*" }]
    }
  ]
}
