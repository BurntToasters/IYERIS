{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IYERIS",
  "version": "3.0.0-beta.3",
  "identifier": "run.rosie.iyeris",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "IYERIS",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "decorations": true,
        "visible": false,
        "backgroundColor": "#181818",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http://asset.localhost; media-src 'self' blob: asset: http://asset.localhost; font-src 'self' data:; frame-src 'none'; connect-src 'self' ipc: http://ipc.localhost https://api.github.com https://github.com asset: http://asset.localhost; object-src 'none'; base-uri 'self'; form-action 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "deny": [
            "$APPDATA/**",
            "$APPLOCALDATA/**",
            "$APPCACHE/**",
            "$APPLOG/**",
            "$RESOURCE/**",
            "$TEMP/**",
            "$HOME/.ssh/**",
            "$HOME/.gnupg/**",
            "$HOME/.aws/**",
            "$HOME/.docker/**",
            "$HOME/.kube/**",
            "**/.ssh/**",
            "**/.gnupg/**",
            "**/.aws/**",
            "**/.docker/**",
            "**/.kube/**",
            "**/.password-store/**",
            "$HOME/.config/gh/**",
            "$HOME/.config/git/credentials",
            "$HOME/.git-credentials",
            "$HOME/.npmrc",
            "$HOME/.yarnrc",
            "$HOME/.yarnrc.yml",
            "$HOME/.pypirc",
            "$HOME/.cargo/credentials*",
            "$HOME/.gem/credentials",
            "$HOME/.password-store/**",
            "$HOME/.config/1Password/**",
            "$HOME/.config/Bitwarden/**",
            "$HOME/.config/google-chrome/**",
            "$HOME/.config/BraveSoftware/**",
            "$HOME/.config/chromium/**",
            "$HOME/.mozilla/firefox/**",
            "$HOME/Library/Application Support/Google/Chrome/**",
            "$HOME/Library/Application Support/Firefox/**",
            "$HOME/Library/Application Support/BraveSoftware/**",
            "$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/**",
            "$HOME/Library/Keychains/**",
            "$HOME/Library/Cookies/**",
            "$HOME/Library/Mail/**",
            "$HOME/Library/Messages/**",
            "**/.config/**/secrets*",
            "**/.netrc",
            "**/authorized_keys",
            "**/known_hosts",
            "**/id_rsa",
            "**/id_dsa",
            "**/id_ecdsa",
            "**/id_ed25519",
            "**/*_rsa",
            "**/*_dsa",
            "**/*_ecdsa",
            "**/*_ed25519",
            "**/*.pem",
            "**/*.key",
            "**/*.pfx",
            "**/*.p12",
            "**/login.keychain*"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "nsis", "msi", "appimage", "deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      },
      "wix": {}
    },
    "macOS": {
      "entitlements": "entitlements.plist",
      "hardenedRuntime": true,
      "infoPlist": "Info.plist",
      "minimumSystemVersion": "14.0"
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/BurntToasters/IYERIS/releases/latest/download/latest-{{target}}-{{arch}}.json",
        "https://github.com/BurntToasters/IYERIS/releases/download/v{{current_version}}/latest-{{target}}-{{arch}}.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZDNzY0QzNGQTREMDVENjMKUldSalhkQ2tQMHgyL0Q1MzVEckJXU05jS0ZMa2lqOGdGZnoxTHpYL1J5Y2JhdFVwNzY1bmFreEIK"
    }
  }
}
