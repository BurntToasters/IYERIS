{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IYERIS",
  "version": "2.1.1-beta.2",
  "identifier": "run.rosie.iyeris",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "IYERIS",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "decorations": true,
        "visible": false,
        "backgroundColor": "#181818"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http://asset.localhost; media-src 'self' blob: asset: http://asset.localhost; font-src 'self' data:; frame-src 'none'; connect-src 'self' ipc: http://ipc.localhost https://api.github.com https://github.com asset: http://asset.localhost; object-src 'none'; base-uri 'self'; form-action 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "deny": [
            "$APPDATA/**",
            "$APPLOCALDATA/**",
            "$APPCACHE/**",
            "$APPLOG/**",
            "$RESOURCE/**",
            "$HOME/.ssh/**",
            "$HOME/.gnupg/**",
            "$HOME/.aws/**",
            "$HOME/.docker/**",
            "$HOME/.kube/**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "nsis", "msi", "appimage", "deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      },
      "wix": {}
    },
    "macOS": {
      "entitlements": "entitlements.plist",
      "hardenedRuntime": true,
      "infoPlist": "Info.plist",
      "minimumSystemVersion": "14.0"
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/BurntToasters/IYERIS/releases/latest/download/latest-{{target}}-{{arch}}.json",
        "https://github.com/BurntToasters/IYERIS/releases/download/v{{current_version}}/latest-{{target}}-{{arch}}.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ1NTNBOTc5QTJFMkI4OTAKUldTUXVPS2llYWxUUlExc3Jtb0krdVFtUnFXYTZMdVdoVWJ3VWxjT3pCZHUyMjByWHpyV3l5TVAK"
    }
  }
}
