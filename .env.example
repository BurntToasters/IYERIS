GH_TOKEN=

GPG_KEY_ID=
GPG_PASSPHRASE=

TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# Windows Authenticode signing via Azure Artifact Signing (Public Trust)
# AZURE_CLIENT_SECRET is secret; never commit real credentials.
# Once per Windows release VM (as Administrator), run: npm run setup:win:artifact-signing
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=
AZURE_CLIENT_SECRET=
AZURE_ARTIFACT_SIGNING_ENDPOINT=
AZURE_ARTIFACT_SIGNING_ACCOUNT=
AZURE_ARTIFACT_SIGNING_PROFILE=
AZURE_ARTIFACT_SIGNING_PUBLISHER=
# Optional overrides if Client Tools are installed in a nonstandard location:
# AZURE_ARTIFACT_SIGNING_SIGNTOOL_PATH=
# AZURE_ARTIFACT_SIGNING_DLIB_PATH=

APPLE_SIGNING_IDENTITY=
APPLE_ID=
APPLE_PASSWORD=
APPLE_TEAM_ID=
# Legacy alias supported when APPLE_PASSWORD is unset:
# APPLE_APP_SPECIFIC_PASSWORD=
SSH_USER_PWD=

AFTER_PACK_LOC=

MSSTORE_IDENTITY_NAME=
MSSTORE_PUBLISHER=
MSSTORE_PUBLISHER_DISPLAY_NAME=

# GH_REPO_OWNER=BurntToasters
# GH_REPO_NAME=IYERIS
